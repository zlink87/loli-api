    {
      "name": "3. Job Management",
      "item": [
        {
          "name": "Get Job Status (with Image Preview)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "var status = jsonData.status;",
                  "",
                  "// Status indicator",
                  "var statusEmoji = {",
                  "    'queued': '⏳',",
                  "    'running': '🔄',",
                  "    'succeeded': '✅',",
                  "    'failed': '❌'",
                  "};",
                  "",
                  "console.log(statusEmoji[status] + ' Status: ' + status);",
                  "",
                  "if (jsonData.progress) {",
                  "    console.log('Progress: ' + (jsonData.progress * 100).toFixed(1) + '%');",
                  "}",
                  "",
                  "// When job succeeds, save preview URLs and show visualizer",
                  "if (status === 'succeeded' && jsonData.results && jsonData.results.length > 0) {",
                  "    // Save first preview URL for quick access",
                  "    var firstUrl = jsonData.results[0].previewUrl;",
                  "    pm.collectionVariables.set('last_preview_url', firstUrl);",
                  "    ",
                  "    // Save all URLs",
                  "    var allUrls = jsonData.results.map(function(r) { return r.previewUrl; });",
                  "    pm.collectionVariables.set('all_preview_urls', JSON.stringify(allUrls));",
                  "    ",
                  "    console.log('');",
                  "    console.log('🖼️  ' + jsonData.results.length + ' image(s) ready!');",
                  "    console.log('📌 Preview URL saved to {{last_preview_url}}');",
                  "    console.log('');",
                  "    console.log('👉 Click the \"Visualize\" tab below to see the image(s)!');",
                  "    ",
                  "    if (jsonData.promptUsed) {",
                  "        console.log('');",
                  "        console.log('Prompt: ' + jsonData.promptUsed.substring(0, 100) + '...');",
                  "    }",
                  "    if (jsonData.seedUsed) {",
                  "        console.log('Seed: ' + jsonData.seedUsed);",
                  "    }",
                  "    ",
                  "    // Build HTML for visualizer",
                  "    var template = `",
                  "    <style>",
                  "        .container { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; padding: 20px; }",
                  "        .status { background: #10b981; color: white; padding: 8px 16px; border-radius: 20px; display: inline-block; margin-bottom: 20px; }",
                  "        .images { display: flex; flex-wrap: wrap; gap: 20px; }",
                  "        .image-card { background: #f3f4f6; border-radius: 12px; overflow: hidden; max-width: 400px; }",
                  "        .image-card img { width: 100%; height: auto; display: block; }",
                  "        .image-info { padding: 12px; font-size: 12px; }",
                  "        .image-info a { color: #3b82f6; word-break: break-all; }",
                  "        .meta { margin-top: 20px; padding: 16px; background: #f9fafb; border-radius: 8px; font-size: 13px; }",
                  "        .meta-row { display: flex; margin-bottom: 8px; }",
                  "        .meta-label { font-weight: 600; width: 100px; color: #6b7280; }",
                  "        .prompt { margin-top: 12px; padding: 12px; background: #e5e7eb; border-radius: 6px; font-size: 12px; line-height: 1.5; max-height: 150px; overflow-y: auto; }",
                  "    </style>",
                  "    <div class='container'>",
                  "        <div class='status'>✅ Job Succeeded</div>",
                  "        <div class='images'>",
                  "            {{#each results}}",
                  "            <div class='image-card'>",
                  "                <img src='{{previewUrl}}' alt='Generated Image {{@index}}' />",
                  "                <div class='image-info'>",
                  "                    <strong>Image {{math @index '+' 1}}</strong><br>",
                  "                    <a href='{{previewUrl}}' target='_blank'>Open in new tab ↗</a>",
                  "                </div>",
                  "            </div>",
                  "            {{/each}}",
                  "        </div>",
                  "        <div class='meta'>",
                  "            <div class='meta-row'><span class='meta-label'>Job ID:</span> {{jobId}}</div>",
                  "            {{#if seedUsed}}<div class='meta-row'><span class='meta-label'>Seed:</span> {{seedUsed}}</div>{{/if}}",
                  "            {{#if expiresAt}}<div class='meta-row'><span class='meta-label'>Expires:</span> {{expiresAt}}</div>{{/if}}",
                  "            {{#if promptUsed}}<div class='prompt'><strong>Prompt:</strong><br>{{promptUsed}}</div>{{/if}}",
                  "        </div>",
                  "    </div>",
                  "    `;",
                  "    ",
                  "    // Add helper for math",
                  "    pm.visualizer.set(template, jsonData);",
                  "",
                  "} else if (status === 'failed') {",
                  "    console.log('');",
                  "    console.log('Error:', jsonData.error ? jsonData.error.code + ' - ' + jsonData.error.message : 'Unknown error');",
                  "    ",
                  "    var errorTemplate = `",
                  "    <div style='font-family: sans-serif; padding: 20px;'>",
                  "        <div style='background: #ef4444; color: white; padding: 8px 16px; border-radius: 20px; display: inline-block;'>❌ Job Failed</div>",
                  "        <div style='margin-top: 20px; padding: 16px; background: #fef2f2; border-radius: 8px; border: 1px solid #fecaca;'>",
                  "            <strong>Error:</strong> {{error.code}}<br>",
                  "            <span style='color: #991b1b;'>{{error.message}}</span>",
                  "        </div>",
                  "    </div>",
                  "    `;",
                  "    pm.visualizer.set(errorTemplate, jsonData);",
                  "    ",
                  "} else {",
                  "    // Still processing",
                  "    console.log('');",
                  "    console.log('⏳ Job still processing. Run this request again to check status.');",
                  "    ",
                  "    var progressTemplate = `",
                  "    <div style='font-family: sans-serif; padding: 20px; text-align: center;'>",
                  "        <div style='font-size: 48px; margin-bottom: 20px;'>{{#if (eq status 'queued')}}⏳{{else}}🔄{{/if}}</div>",
                  "        <div style='background: #3b82f6; color: white; padding: 8px 16px; border-radius: 20px; display: inline-block;'>{{status}}</div>",
                  "        {{#if progress}}",
                  "        <div style='margin-top: 20px;'>",
                  "            <div style='background: #e5e7eb; border-radius: 10px; height: 20px; overflow: hidden;'>",
                  "                <div style='background: #3b82f6; height: 100%; width: {{math progress '*' 100}}%;'></div>",
                  "            </div>",
                  "            <div style='margin-top: 8px; color: #6b7280;'>{{math progress '*' 100}}% complete</div>",
                  "        </div>",
                  "        {{/if}}",
                  "        <p style='color: #6b7280; margin-top: 20px;'>Run this request again to refresh status</p>",
                  "    </div>",
                  "    `;",
                  "    pm.visualizer.set(progressTemplate, jsonData);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/v1/jobs/{{last_job_id}}",
            "description": "Poll job status with automatic image preview!\n\n**When job succeeds:**\n- Click the 'Visualize' tab to see the image(s) directly\n- Preview URL is saved to {{last_preview_url}}\n- Click 'Open in new tab' to view full size\n\n**Status progression:** queued → running → succeeded/failed"
          },
          "response": []
        },
        {
          "name": "Get Job Status (Manual ID)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/v1/jobs/imgjob_xxxxx",
            "description": "Replace 'imgjob_xxxxx' with actual job ID."
          },
          "response": []
        },
        {
          "name": "Cancel Job",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/v1/jobs/{{last_job_id}}",
            "description": "Cancel a queued job. Only works for jobs in 'queued' status. Returns 204 No Content on success."
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. View Images",
      "item": [
        {
          "name": "View Last Generated Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    console.log('✅ Image loaded successfully!');",
                  "    console.log('');",
                  "    console.log('👉 Check the response body or Visualize tab to see the image.');",
                  "    ",
                  "    // Display image in visualizer",
                  "    var template = `",
                  "    <div style='font-family: sans-serif; padding: 20px;'>",
                  "        <div style='background: #10b981; color: white; padding: 8px 16px; border-radius: 20px; display: inline-block; margin-bottom: 20px;'>✅ Image Loaded</div>",
                  "        <div style='background: #f3f4f6; border-radius: 12px; overflow: hidden; display: inline-block;'>",
                  "            <img src='{{url}}' style='max-width: 100%; max-height: 80vh; display: block;' />",
                  "        </div>",
                  "    </div>",
                  "    `;",
                  "    pm.visualizer.set(template, { url: pm.collectionVariables.get('last_preview_url') });",
                  "} else {",
                  "    console.log('❌ Failed to load image. Status:', pm.response.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var previewUrl = pm.collectionVariables.get('last_preview_url');",
                  "if (!previewUrl) {",
                  "    console.log('❌ No preview URL saved. Generate an image first!');",
                  "    throw new Error('No preview URL available. Run a generate request first.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{last_preview_url}}",
            "description": "Quickly view the last generated image without copying URLs!\n\nThis uses the automatically saved {{last_preview_url}} from the job status.\n\n**Prerequisites:**\n1. Generate an image\n2. Run 'Get Job Status' until succeeded\n3. Run this request to view the image"
          },
          "response": []
        },
        {
          "name": "View Image (Paste URL Here)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var template = `",
                  "    <div style='font-family: sans-serif; padding: 20px;'>",
                  "        <img src='{{url}}' style='max-width: 100%; max-height: 80vh;' />",
                  "    </div>",
                  "    `;",
                  "    pm.visualizer.set(template, { url: pm.request.url.toString() });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/preview/PASTE_TOKEN_HERE?path=PASTE_PATH_HERE",
              "host": ["{{base_url}}"],
              "path": ["v1", "preview", "PASTE_TOKEN_HERE"],
              "query": [
                {
                  "key": "path",
                  "value": "PASTE_PATH_HERE"
                }
              ]
            },
