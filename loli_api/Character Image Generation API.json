                  "}",
                  "if (jsonData.results && jsonData.results.length > 0) {",
                  "    pm.collectionVariables.set('last_preview_url', jsonData.results[0].previewUrl);",
                  "    console.log('🖼️  ' + jsonData.results.length + ' image(s) edited!');",
                  "    console.log('📌 Preview URL saved to {{last_preview_url}}');",
                  "    ",
                  "    // Build visualizer",
                  "    var template = `",
                  "    <style>",
                  "        .container { font-family: sans-serif; padding: 20px; }",
                  "        .status { background: #10b981; color: white; padding: 8px 16px; border-radius: 20px; display: inline-block; margin-bottom: 20px; }",
                  "        .image-card { background: #f3f4f6; border-radius: 12px; overflow: hidden; display: inline-block; }",
                  "        .image-card img { max-width: 100%; max-height: 70vh; display: block; }",
                  "        .info { padding: 12px; }",
                  "        .info a { color: #3b82f6; }",
                  "    </style>",
                  "    <div class='container'>",
                  "        <div class='status'>✅ Edit Complete</div>",
                  "        {{#each results}}",
                  "        <div class='image-card'>",
                  "            <img src='{{previewUrl}}' />",
                  "            <div class='info'><a href='{{previewUrl}}' target='_blank'>Open in new tab ↗</a></div>",
                  "        </div>",
                  "        {{/each}}",
                  "    </div>",
                  "    `;",
                  "    pm.visualizer.set(template, jsonData);",
                  "}",
                  "if (jsonData.expiresAt) {",
                  "    console.log('Expires at:', jsonData.expiresAt);",
                  "}"
