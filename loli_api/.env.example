# ===========================================
# Character Image Generation API Configuration
# ===========================================

# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=false

# JWT Authentication
# IMPORTANT: Change these in production!
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ComfyUI Configuration
COMFYUI_SERVER_ADDRESS=127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=workflows/amazing-z-photo_API_Create_CHAR.json

# xAI Grok-4 API
XAI_API_KEY=your-xai-api-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4

# Storage Configuration
STORAGE_DIR=./storage/images
STORAGE_SIGNING_SECRET=your-signing-secret-for-urls-change-in-production
BASE_URL=http://localhost:8001
PREVIEW_EXPIRY_MINUTES=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Queue Configuration
MAX_QUEUE_SIZE=100
