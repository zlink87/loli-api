# =============================================================================
# loli-api environment configuration
# Copy to .env and fill in. In production (DEBUG=false) the app refuses to start
# unless the secrets + RunPod + CORS + SSRF settings below are set (see main.py
# _validate_production_settings).
# =============================================================================

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=false
LOG_LEVEL=INFO

# --- GPU backend: "runpod" (serverless, default) or "local" (legacy WebSocket) ---
GPU_BACKEND=runpod

# --- RunPod Serverless (see docs/RUNPOD_SETUP.md) ---
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_BASE_URL=https://api.runpod.ai/v2
RUNPOD_EXECUTION_TIMEOUT_MS=600000
RUNPOD_TTL_MS=3600000
RUNPOD_POLL_INTERVAL_SECONDS=5
RUNPOD_MAX_IN_FLIGHT=50
# How edit source images reach the worker: "base64" (default, works with stock LoadImage)
# or "url" (requires a URL-capable loader node on the worker).
RUNPOD_SOURCE_IMAGE_MODE=base64

# --- Authentication ---
# Primary: verify Supabase user JWTs (Settings -> API -> JWT secret in Supabase).
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
# Internal HS256 secret (fallback / service tokens) — MUST be changed from default.
JWT_SECRET_KEY=change-me-to-a-random-32-char-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Security ---
# Comma-separated CORS allowlist (admin panel + website). Empty => cross-origin blocked.
CORS_ALLOW_ORIGINS=https://admin.example.com,https://example.com
# Comma-separated host allowlist for source_image URLs (SSRF guard). Use your Supabase host.
SOURCE_IMAGE_ALLOWED_HOSTS=your-project-ref.supabase.co
# Signing secret for local preview URLs — MUST be changed from default.
STORAGE_SIGNING_SECRET=change-me-to-a-random-32-char-secret

# --- Supabase storage (output images) ---
USE_SUPABASE_STORAGE=true
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=images_generated
SUPABASE_UPDATE_BASE_URL_API_KEY=

# Supabase S3 endpoint (the RunPod worker uploads output here directly; mirror these
# onto the RunPod endpoint as BUCKET_ENDPOINT_URL / BUCKET_ACCESS_KEY_ID / BUCKET_SECRET_ACCESS_KEY).
SUPABASE_S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

# --- xAI Grok (prompt polishing; optional — deterministic assembler works without it) ---
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4

# --- Storage / misc ---
STORAGE_DIR=./storage/images
BASE_URL=http://localhost:8001
PREVIEW_EXPIRY_MINUTES=60
MAX_QUEUE_SIZE=100

# --- Notifications (optional) ---
GOOGLE_CHAT_RESPONSE_WEBHOOK_URL=
GOOGLE_CHAT_PAYLOAD_WEBHOOK_URL=

# --- Local ComfyUI (only used when GPU_BACKEND=local) ---
COMFYUI_SERVER_ADDRESS=127.0.0.1:8188
